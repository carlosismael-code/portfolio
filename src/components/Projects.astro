---
import { getCollection } from 'astro:content';
import SectionHeading from '~/components/SectionHeading.astro';
import ProjectCard from '~/components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="page-section border-t border-[var(--border)]" aria-labelledby="projects-title">
  <div class="container-page relative">
    <span class="section-number" aria-hidden="true"><span>03</span></span>

    <SectionHeading
      title="Projetos selecionados"
      description="Cada case traz problema, decisão técnica e o que aprendi. Clique em 'ver case' para o detalhamento."
      number="03"
    />

    <div class="grid gap-6 md:grid-cols-2 reveal-stagger">
      {projects.map((project, i) => <ProjectCard project={project} index={i} />)}
    </div>
  </div>
</section>
