---
import SectionHeading from '~/components/SectionHeading.astro';

interface EducationItem {
  type: 'degree' | 'cert';
  title: string;
  org: string;
  location?: string;
  period: string;
  description: string;
  tags?: string[];
  highlight?: string;
}

const items: EducationItem[] = [
  {
    type: 'degree',
    title: 'Análise e Desenvolvimento de Sistemas',
    org: 'Fasul Educacional',
    location: 'São Lourenço, Minas Gerais',
    period: '2025 — 2027',
    description: 'Formação técnica com foco em desenvolvimento de software, banco de dados e engenharia. Projetos práticos em back-end, modelagem de dados e versionamento.',
    tags: ['ADS', 'Banco de Dados', 'Engenharia de Software'],
    highlight: 'Em curso',
  },
  {
    type: 'cert',
    title: 'Programador Web',
    org: 'Instituto Federal de Educação, Ciência e Tecnologia — Rio Grande do Sul',
    period: 'Jun/2025',
    description: 'Conteúdo: HTML, CSS, Lógica de Programação, JavaScript, Banco de Dados, Projetos de Sistemas Web.',
    tags: ['HTML', 'CSS', 'JavaScript', 'Lógica de Programação', 'Banco de Dados'],
    highlight: 'Aproveitamento: 80,84% · 200h',
  },
  {
    type: 'cert',
    title: 'Django Master — APIs Modernas com Python e Django',
    org: 'PycodeBR',
    period: 'Mai/2026',
    description: 'Construção de APIs REST com Python e Django, boas práticas de arquitetura e deploy.',
    tags: ['Python', 'Django', 'APIs REST'],
    highlight: '18h',
  },
  {
    type: 'cert',
    title: 'Imersão IA Builders — Workflow de Desenvolvimento com IA Assistida',
    org: 'PycodeBR',
    period: 'Jun/2026',
    description: 'Fluxo de trabalho com IA assistida para desenvolvimento de software, automação de tarefas e produtividade.',
    tags: ['IA', 'Automação', 'Produtividade'],
    highlight: '6h',
  },
];
---

<section id="education" class="page-section page-section--alt border-t border-[var(--border)]" aria-labelledby="education-title">
  <div class="container-page relative">
    <span class="section-number" aria-hidden="true"><span>06</span></span>

    <SectionHeading
      title="Formação & Certificações"
      description="Graduação, cursos e certificações que construíram minha base técnica."
      number="06"
    />

    <ol class="relative space-y-10 border-l border-[var(--border)] pl-6 sm:pl-8 reveal-stagger">
      {
        items.map((item) => (
          <li class="relative">
            <span
              class:list={[
                'absolute -left-[33px] sm:-left-[41px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2',
                item.type === 'degree'
                  ? 'border-[var(--accent)] bg-[var(--accent)]'
                  : 'border-[var(--orange)] bg-[var(--bg)]',
              ]}
              aria-hidden="true"
            />
            <div class="flex flex-col gap-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)] lowercase tracking-widest">
                  {item.period}
                </span>
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)]">·</span>
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)] lowercase tracking-widest">
                  {item.type === 'degree' ? 'graduação' : 'certificação'}
                </span>
                {item.highlight && (
                  <>
                    <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)]">·</span>
                    <span class="font-mono text-[var(--text-2xs)] text-[var(--accent)] lowercase tracking-widest">
                      {item.highlight}
                    </span>
                  </>
                )}
              </div>
              <h3 class="font-display font-semibold text-[var(--text-lg)] tracking-tightish">
                {item.title}
              </h3>
              <p class="font-mono text-[var(--text-xs)] text-[var(--fg-secondary)] lowercase">
                {item.org}
                {item.location && ` — ${item.location}`}
              </p>
              <p class="text-[var(--fg-secondary)] leading-relaxed max-w-2xl font-display">
                {item.description}
              </p>
              {item.tags && (
                <ul class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <li class="work-tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
