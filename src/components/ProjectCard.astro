---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const { data, id } = project;

const statusLabels = {
  shipped: 'shipped',
  wip: 'em desenvolvimento',
  archived: 'arquivado',
} as const;

const glyphIndex = (index % 3) + 1;
const glyphClass = glyphIndex === 1 ? 'glyph--blue' : glyphIndex === 2 ? 'glyph--orange' : 'glyph--black';

const glyphs: Record<number, boolean[]> = {
  1: [true, false, true, false, false, true, true, true, false],
  2: [false, false, false, true, true, true, false, false, false],
  3: [false, true, false, true, true, true, false, true, false],
};
---

<article
  class="work-card group reveal"
  style={`transition-delay: ${index * 80}ms`}
>
  <header class="flex items-start justify-between gap-3">
    <div class="flex flex-col gap-2">
      <div class={`glyph ${glyphClass}`} aria-hidden="true">
        <div class="glyph__grid">
          {glyphs[glyphIndex].map((filled) => (
            <span class="glyph__cell" data-filled={String(filled)}></span>
          ))}
        </div>
      </div>
      <h3 class="work-card__title text-[var(--text-lg)] mt-1">
        {data.title}
      </h3>
      <p class="work-card__meta">
        {data.role ?? 'creator'} {data.role ? '·' : ''} {data.year ?? '—'}
      </p>
    </div>
    <span
      class:list={[
        'shrink-0 inline-flex items-center font-mono text-[var(--text-2xs)] px-2 py-1 border border-[var(--border)] text-[var(--fg-secondary)] lowercase tracking-wide',
      ]}
    >
      {statusLabels[data.status]}
    </span>
  </header>

  <p class="text-[var(--fg-secondary)] leading-relaxed font-display">
    {data.summary}
  </p>

  {
    data.highlights.length > 0 && (
      <ul class="text-sm text-[var(--fg-secondary)] space-y-1.5 font-mono">
        {data.highlights.map((h) => (
          <li class="flex items-start gap-2">
            <span class="text-[var(--accent)] mt-1 shrink-0">▸</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    )
  }

  <footer class="mt-auto pt-2 flex flex-col gap-3">
    <ul class="flex flex-wrap gap-1.5">
      {
        data.stack.map((tech) => (
          <li class="work-tag">{tech}</li>
        ))
      }
    </ul>

    <div class="flex items-center gap-4 font-mono text-[var(--text-xs)]">
      <a
        href={`/projects/${id}/`}
        class="inline-flex items-center gap-1 text-[var(--fg)] hover:text-[var(--accent)] no-underline"
      >
        ver case
        <span aria-hidden="true">→</span>
      </a>
      {
        data.github && (
          <a
            href={data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-[var(--fg-secondary)] hover:text-[var(--fg)] no-underline"
          >
            github
          </a>
        )
      }
      {
        data.demo && (
          <a
            href={data.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-[var(--fg-secondary)] hover:text-[var(--fg)] no-underline"
          >
            demo
          </a>
        )
      }
    </div>
  </footer>
</article>
