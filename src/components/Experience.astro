---
import SectionHeading from '~/components/SectionHeading.astro';

interface ExperienceItem {
  title: string;
  org: string;
  period: string;
  description: string;
  duties: string[];
  tags?: string[];
}

const items: ExperienceItem[] = [
  {
    title: 'Técnico em Manutenção de Redes Externas',
    org: 'Blink Telecom',
    period: 'Atual',
    description: 'Manutenção e suporte de infraestrutura de telecomunicações com foco em redes FTTH.',
    duties: [
      'Manutenção e suporte de redes FTTH',
      'Diagnóstico e reparo de infraestrutura de fibra ótica',
      'Conhecimento prático de topologia, emendas e equipamentos OTDR',
    ],
    tags: ['FTTH', 'Fibra Ótica', 'OTDR', 'Redes', 'Infraestrutura'],
  },
];
---

<section id="experience" class="page-section border-t border-[var(--border)]" aria-labelledby="experience-title">
  <div class="container-page relative">
    <span class="section-number" aria-hidden="true"><span>07</span></span>

    <SectionHeading
      title="Experiência Profissional"
      description="Onde aplico meu conhecimento no mundo real."
      number="07"
    />

    <ol class="relative space-y-10 border-l border-[var(--border)] pl-6 sm:pl-8 reveal-stagger">
      {
        items.map((item) => (
          <li class="relative">
            <span
              class="absolute -left-[33px] sm:-left-[41px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2 border-[var(--accent)] bg-[var(--bg)]"
              aria-hidden="true"
            />
            <div class="flex flex-col gap-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)] lowercase tracking-widest">
                  {item.period}
                </span>
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)]">·</span>
                <span class="font-mono text-[var(--text-2xs)] text-[var(--fg-secondary)] lowercase tracking-widest">
                  experiência
                </span>
              </div>
              <h3 class="font-display font-semibold text-[var(--text-lg)] tracking-tightish">
                {item.title}
              </h3>
              <p class="font-mono text-[var(--text-xs)] text-[var(--fg-secondary)] lowercase">
                {item.org}
              </p>
              <p class="text-[var(--fg-secondary)] leading-relaxed max-w-2xl font-display">
                {item.description}
              </p>
              {item.duties.length > 0 && (
                <ul class="text-sm text-[var(--fg-secondary)] space-y-1.5 font-mono">
                  {item.duties.map((duty) => (
                    <li class="flex items-start gap-2">
                      <span class="text-[var(--accent)] mt-1 shrink-0">▸</span>
                      <span>{duty}</span>
                    </li>
                  ))}
                </ul>
              )}
              {item.tags && (
                <ul class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <li class="work-tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
